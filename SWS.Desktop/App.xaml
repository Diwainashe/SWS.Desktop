<Application x:Class="SWS.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SWS.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Shared control styles -->
                <ResourceDictionary Source="Themes/Controls.xaml"/>

                <!-- Default theme (will be swapped by AppThemeService) -->
                <ResourceDictionary Source="Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:HexToColorBrushConverter x:Key="HexToColorBrushConverter"/>
            <conv:PageKeyToBoolConverter x:Key="PageKeyToBoolConverter"/>
            <conv:TimeRangeConverter x:Key="TimeRangeConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>