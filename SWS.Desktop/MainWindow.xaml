<Window x:Class="SWS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:SWS.Desktop.Services"
        Title="SWS"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource App.BackgroundBrush}">

    

    <DockPanel>

        <!-- TOP BAR -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource App.TopBarBrush}"
                BorderBrush="{DynamicResource App.TopBarBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Engineering logo placeholder -->
                <Border Width="100" Height="100"
                        Background="{DynamicResource App.LogoFrameBrush}"
                        BorderBrush="{DynamicResource App.LogoFrameBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <Image Source="{Binding EngineeringLogoImage}"
                           Stretch="Uniform"
                           Margin="6"/>
                </Border>

                <!-- Center: nav -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="SWS"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center"/>

                    <RadioButton Content="Dashboard"
                                 GroupName="TopNav"
                                 Style="{StaticResource NavTabStyle}"
                                 Margin="0,0,6,0"
                                 IsChecked="{Binding CurrentPage, Mode=TwoWay, Converter={StaticResource PageKeyToBoolConverter}, ConverterParameter={x:Static svc:AppPageKey.Dashboard}}"/>

                    <RadioButton Content="Devices"
                                 GroupName="TopNav"
                                 Style="{StaticResource NavTabStyle}"
                                 Margin="0,0,6,0"
                                 IsChecked="{Binding CurrentPage, Mode=TwoWay, Converter={StaticResource PageKeyToBoolConverter}, ConverterParameter={x:Static svc:AppPageKey.Devices}}"/>

                    <RadioButton Content="Points"
                                 GroupName="TopNav"
                                 Style="{StaticResource NavTabStyle}"
                                 Margin="0,0,6,0"
                                 IsChecked="{Binding CurrentPage, Mode=TwoWay, Converter={StaticResource PageKeyToBoolConverter}, ConverterParameter={x:Static svc:AppPageKey.Points}}"/>

                    <RadioButton Content="Trend"
                                 GroupName="TopNav"
                                 Style="{StaticResource NavTabStyle}"
                                 Margin="0,0,6,0"
                                 IsChecked="{Binding CurrentPage, Mode=TwoWay, Converter={StaticResource PageKeyToBoolConverter}, ConverterParameter={x:Static svc:AppPageKey.Trend}}"/>

                    <RadioButton Content="Settings"
                                 GroupName="TopNav"
                                 Style="{StaticResource NavTabStyle}"
                                 IsChecked="{Binding CurrentPage, Mode=TwoWay, Converter={StaticResource PageKeyToBoolConverter}, ConverterParameter={x:Static svc:AppPageKey.Settings}}"/>
                </StackPanel>

                <!-- Right: Client logo placeholder -->
                <Border Grid.Column="2"
                        Width="100" Height="100"
                        Background="{DynamicResource App.LogoFrameBrush}"
                        BorderBrush="{DynamicResource App.LogoFrameBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        VerticalAlignment="Center">
                    <Image Source="{Binding ClientLogoImage}"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"/>
                </Border>
            </Grid>
        </Border>

        <!-- PAGE HOST -->
        <ContentControl Content="{Binding Navigation.CurrentView}" />
    </DockPanel>
</Window>