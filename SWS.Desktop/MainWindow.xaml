<Window x:Class="SWS.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SWS" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="#1E1E1E" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="SWS"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Dashboard"
                            Margin="0,0,8,0"
                            Padding="14,6"
                            Command="{Binding GoDashboardCommand}"/>

                    <Button Content="Config"
                            Padding="14,6"
                            Command="{Binding GoConfigCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Active page -->
        <ContentControl Content="{Binding Navigation.CurrentView}" />
    </DockPanel>
</Window>