<UserControl x:Class="SWS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- tiles -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════
             HEADER
             ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Devices"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource App.TextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Status}"
                           FontSize="12"
                           Foreground="{StaticResource App.MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Refresh"
                        Padding="10,5" Margin="0,0,8,0"
                        Command="{Binding RefreshCommand}"/>
                <Button Padding="10,5"
                        Command="{Binding ToggleAutoRefreshCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Auto: ON"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AutoRefresh}" Value="False">
                                    <Setter Property="Content" Value="Auto: OFF"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════
             TILES
             ══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- Empty state -->
            <Grid>
                <TextBlock Text="No devices connected yet.&#x0a;Add a device in the Devices page."
                           Foreground="{StaticResource App.MutedTextBrush}"
                           FontSize="14"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           LineHeight="24">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tiles.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Tiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <!-- Whole tile is a button surface -->
                            <Border Width="280" Margin="0,0,12,12"
                                    CornerRadius="6"
                                    Cursor="Hand"
                                    BorderThickness="1">

                                <!-- Dynamic border colour: alarm = red, running = green, stopped = default -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{StaticResource App.SurfaceBrush}"/>
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource App.BorderBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FF4444"/>
                                                <Setter Property="Background"  Value="#1A0A0A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RunState}" Value="Running">
                                                <Setter Property="BorderBrush" Value="#2ECC71"/>
                                                <Setter Property="Background"  Value="#0A1A10"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <!-- Click handler via transparent button overlay -->
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenTileCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <!-- title bar -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- metrics -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- footer -->
                                    </Grid.RowDefinitions>

                                    <!-- ── Title bar ── -->
                                    <Border Grid.Row="0"
                                            Padding="14,10"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource App.BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding DeviceName}"
                                                           FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{StaticResource App.TextBrush}"/>
                                                <TextBlock Text="{Binding DeviceType}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource App.MutedTextBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Run state badge -->
                                            <Border Grid.Column="1"
                                                    Padding="7,3" CornerRadius="3"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding RunStateColor}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding RunState}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- ── Metrics ── -->
                                    <Grid Grid.Row="1" Margin="14,12,14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="1"/>
                                            <!-- divider -->
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Weight -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="WEIGHT"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource App.MutedTextBrush}"
                                                       Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Weight}"
                                                       FontSize="20" FontWeight="Light"
                                                       Foreground="{StaticResource App.TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Vertical divider -->
                                        <Rectangle Grid.Column="1"
                                                   Fill="{StaticResource App.BorderBrush}"
                                                   Width="1" Margin="10,0"/>

                                        <!-- Flowrate -->
                                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                            <TextBlock Text="FLOWRATE"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource App.MutedTextBrush}"
                                                       Margin="0,0,0,3"/>
                                            <TextBlock Text="{Binding Flowrate}"
                                                       FontSize="20" FontWeight="Light"
                                                       Foreground="{StaticResource App.TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- ── Footer ── -->
                                    <Border Grid.Row="2"
                                            Padding="14,8"
                                            BorderThickness="0,1,0,0"
                                            BorderBrush="{StaticResource App.BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Alarm indicator -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Ellipse Width="7" Height="7"
                                                         VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#2ECC71"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                                                                    <Setter Property="Fill" Value="#FF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock VerticalAlignment="Center" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="No alarms"/>
                                                            <Setter Property="Foreground" Value="#2ECC71"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Margin="4,0,0,0"
                                                           Foreground="#FF4444"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="("/>
                                                    <Run Text="{Binding AlarmCount, Mode=OneWay}"/>
                                                    <Run Text=" active)"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Open hint -->
                                            <TextBlock Grid.Column="1"
                                                       Text="View detail →"
                                                       FontSize="11"
                                                       Foreground="{StaticResource App.MutedTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.6"/>
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
