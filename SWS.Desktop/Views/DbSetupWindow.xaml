<Window x:Class="SWS.Desktop.Views.DbSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Setup"
        Height="380"
        Width="520"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Server -->
            <RowDefinition Height="Auto"/>
            <!-- DB -->
            <RowDefinition Height="Auto"/>
            <!-- Auth checkbox -->
            <RowDefinition Height="Auto"/>
            <!-- Username -->
            <RowDefinition Height="Auto"/>
            <!-- Password -->
            <RowDefinition Height="*"/>
            <!-- Spacer -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="SQL Server Connection"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <!-- Server -->
        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Server (e.g. .\SQLEXPRESS or (localdb)\MSSQLLocalDB)"/>
            <TextBox x:Name="ServerBox" Height="28" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Database -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Database name"/>
            <TextBox x:Name="DatabaseBox" Height="28" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Windows Auth -->
        <CheckBox Grid.Row="3"
                  x:Name="WindowsAuthCheckBox"
                  Content="Use Windows Authentication"
                  IsChecked="True"
                  Margin="0,12,0,0"
                  Checked="WindowsAuthChanged"
                  Unchecked="WindowsAuthChanged"/>

        <!-- Username -->
        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="Username (SQL Login)"/>
            <TextBox x:Name="UsernameTextBox" Height="28" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="5" Margin="0,12,0,0">
            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Height="28" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Test"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Test_Click"/>

            <Button Content="Save &amp; Initialize"
                    Width="150"
                    Margin="0,0,8,0"
                    Click="SaveInit_Click"/>

            <Button Content="Cancel"
                    Width="90"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>