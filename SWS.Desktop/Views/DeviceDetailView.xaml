<UserControl x:Class="SWS.Desktop.Views.DeviceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header bar -->
            <RowDefinition Height="Auto"/>
            <!-- summary cards -->
            <RowDefinition Height="Auto"/>
            <!-- diagnostics -->
            <RowDefinition Height="*"/>
            <!-- point list -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             HEADER BAR
             ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Padding="12,5"
                    Command="{Binding GoBackCommand}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding DeviceName}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource App.TextBrush}"/>
                <Border Margin="12,0,0,0" Padding="8,3" CornerRadius="4"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding RunStateColor}"/>
                    </Border.Background>
                    <TextBlock Text="{Binding RunStateDisplay}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Status}"
                           VerticalAlignment="Center"
                           Opacity="0.6" FontSize="11"
                           Margin="0,0,12,0"/>
                <Button Content="Refresh"
                        Padding="10,5"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             SUMMARY CARDS
             ══════════════════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,12">

            <!-- Weight Card -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="WEIGHT"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource App.MutedTextBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding WeightDisplay}"
                               FontSize="26" FontWeight="Light"
                               Foreground="{StaticResource App.TextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Flowrate Card -->
            <Border Style="{StaticResource CardBorder}" Margin="4,0,4,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="FLOWRATE"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource App.MutedTextBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding FlowrateDisplay}"
                               FontSize="26" FontWeight="Light"
                               Foreground="{StaticResource App.TextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Recipe Card -->
            <Border Style="{StaticResource CardBorder}" Margin="4,0,4,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="RECIPE"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource App.MutedTextBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding RecipeDisplay}"
                               FontSize="26" FontWeight="Light"
                               Foreground="{StaticResource App.TextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Alarm Status Card -->
            <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="ALARM STATUS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource App.MutedTextBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock FontSize="26" FontWeight="Light">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="OK"/>
                                <Setter Property="Foreground" Value="#2ECC71"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAlarms}" Value="True">
                                        <Setter Property="Text" Value="ALARM"/>
                                        <Setter Property="Foreground" Value="#FF4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ══════════════════════════════════════════════════════════
             DIAGNOSTICS PANEL
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Style="{StaticResource CardBorder}"
                Padding="16,12" Margin="0,0,0,12">
            <Expander Header="Diagnostics" IsExpanded="True">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Alarms -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Active Alarms"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource App.MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Diagnostics.AlarmGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource App.TextBrush}"/>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,2,0,0"
                                                               Foreground="{StaticResource App.MutedTextBrush}"
                                                               FontSize="12">
                                                        <Run Text="• "/>
                                                        <Run Text="{Binding Path=.}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- States -->
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="Active States"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource App.MutedTextBrush}"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Diagnostics.StateGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource App.TextBrush}"/>
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,2,0,0"
                                                               Foreground="{StaticResource App.MutedTextBrush}"
                                                               FontSize="12">
                                                        <Run Text="• "/>
                                                        <Run Text="{Binding Path=.}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </Grid>
            </Expander>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             POINT LIST
             ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="All Points"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource App.MutedTextBrush}"
                           Margin="12,10,0,8"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Label"     Binding="{Binding Label}"        Width="180"/>
                        <DataGridTextColumn Header="Key"       Binding="{Binding Key}"           Width="220"/>
                        <DataGridTextColumn Header="Value"     Binding="{Binding DisplayValue}"  Width="160"/>
                        <DataGridTextColumn Header="Quality"   Binding="{Binding Quality}"       Width="90"/>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding TimestampLocal}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</UserControl>
