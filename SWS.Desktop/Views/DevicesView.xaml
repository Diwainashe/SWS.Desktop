<UserControl x:Class="SWS.Desktop.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: list -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="Devices" FontSize="18" FontWeight="SemiBold"/>
            <Button Content="Refresh" Margin="0,10,0,0" Padding="10,4" Command="{Binding RefreshCommand}"/>

            <ListBox Margin="0,10,0,0"
                     ItemsSource="{Binding Devices}"
                     SelectedItem="{Binding SelectedDevice}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding IpAddress}" Opacity="0.7"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Right: editor -->
        <StackPanel Grid.Column="1" Margin="16,0,0,0">
            <TextBlock Text="Edit / Add" FontSize="18" FontWeight="SemiBold"/>

            <TextBlock Text="Name" Margin="0,10,0,0"/>
            <TextBox Text="{Binding EditName}" Height="28"/>

            <TextBlock Text="IP Address" Margin="0,10,0,0"/>
            <TextBox Text="{Binding EditIp}" Height="28"/>

            <TextBlock Text="Port" Margin="0,10,0,0"/>
            <TextBox Text="{Binding EditPort}" Height="28"/>

            <TextBlock Text="UnitId" Margin="0,10,0,0"/>
            <TextBox Text="{Binding EditUnitId}" Height="28"/>

            <TextBlock Text="PollMs" Margin="0,10,0,0"/>
            <TextBox Text="{Binding EditPollMs}" Height="28"/>

            <CheckBox Content="Enabled" Margin="0,10,0,0" IsChecked="{Binding EditEnabled}"/>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="New" Width="90" Margin="0,0,8,0" Command="{Binding NewCommand}"/>
                <Button Content="Save" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                <Button Content="Delete" Width="90" Command="{Binding DeleteCommand}"/>
            </StackPanel>

            <TextBlock Margin="0,16,0,0" Text="{Binding Status}" Opacity="0.8"/>
        </StackPanel>
    </Grid>
</UserControl>