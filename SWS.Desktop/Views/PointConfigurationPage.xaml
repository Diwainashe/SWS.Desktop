<Window x:Class="SWS.Desktop.Views.PointConfigurationPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Point Configuration" Height="300" Width="400">
    <Grid>
        <ComboBox Name="PointTemplateCombo" ItemsSource="{Binding PointTemplates}" DisplayMemberPath="DisplayName" />
        <TextBox Name="AddressInput" />
        <Button Content="Save Point" Command="{Binding SavePointCommand}" />
    </Grid>
</Window>