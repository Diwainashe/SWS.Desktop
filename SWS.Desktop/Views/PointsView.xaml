<UserControl x:Class="SWS.Desktop.Views.PointsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Points" FontSize="18" FontWeight="SemiBold" Margin="0,0,16,0"/>

            <TextBlock Text="Device:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="260"
                      ItemsSource="{Binding Devices}"
                      SelectedItem="{Binding SelectedDevice}"
                      DisplayMemberPath="Name"/>

            <Button Content="Refresh" Margin="12,0,0,0" Padding="10,4" Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- list -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Points}"
                     SelectedItem="{Binding SelectedPoint}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Key}" Opacity="0.7"/>
                            <TextBlock Text="{Binding Address}" Opacity="0.7"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- editor -->
            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                <TextBlock Text="Edit / Add" FontSize="18" FontWeight="SemiBold"/>

                <TextBlock Text="Key" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditKey}" Height="28"/>

                <TextBlock Text="Label" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditLabel}" Height="28"/>

                <TextBlock Text="Unit" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditUnit}" Height="28"/>

                <TextBlock Text="Area" Margin="0,10,0,0"/>
                <ComboBox SelectedItem="{Binding EditArea}" Height="28"
                          ItemsSource="{Binding Areas}"/>

                
                <TextBlock Text="Address (manual style, &lt;=0 = not configured)" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditAddress}" Height="28"/>

                <TextBlock Text="Length" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditLength}" Height="28"/>

                <TextBlock Text="DataType" Margin="0,10,0,0"/>
                <ComboBox SelectedItem="{Binding EditDataType}" Height="28"
                          ItemsSource="{Binding DataTypes}"/>

                <TextBlock Text="Scale" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditScale}" Height="28"/>

                <TextBlock Text="PollRateMs" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditPollRateMs}" Height="28"/>

                <CheckBox Content="Essential (tile)" Margin="0,10,0,0" IsChecked="{Binding EditEssential}"/>
                <CheckBox Content="Log to History" Margin="0,6,0,0" IsChecked="{Binding EditLogToHistory}"/>

                <TextBlock Text="HistoryIntervalMs" Margin="0,10,0,0"/>
                <TextBox Text="{Binding EditHistoryIntervalMs}" Height="28"/>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="New" Width="90" Margin="0,0,8,0" Command="{Binding NewCommand}"/>
                    <Button Content="Save" Width="90" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
                    <Button Content="Delete" Width="90" Command="{Binding DeleteCommand}"/>
                </StackPanel>

                <TextBlock Margin="0,16,0,0" Text="{Binding Status}" Opacity="0.8"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>