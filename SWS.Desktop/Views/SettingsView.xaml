<UserControl x:Class="SWS.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Width="700">

            <TextBlock Text="Theme" Opacity="0.8"/>
            <ComboBox Height="35"
                      ItemsSource="{Binding Themes}"
                      SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>

            <TextBlock Text="Engineering Logo Path (left)" Margin="0,14,0,0" Opacity="0.8"/>
            <TextBox Height="35" Text="{Binding EngineeringLogoPath}"/>
            <Border Margin="0,8,0,0"
                    Width="140" Height="70"
                    Background="{DynamicResource App.LogoFrameBrush}"
                    BorderBrush="{DynamicResource App.LogoFrameBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                            <Image Source="{Binding EngineeringLogoPreview}"
                       Stretch="Uniform"
                       Margin="8"/>
            </Border>
            <Button Content="Browse…" Width="120" Margin="0,8,0,0" Command="{Binding BrowseEngineeringLogoCommand}"/>

            <TextBlock Text="Client Logo Path (right)" Margin="0,14,0,0" Opacity="0.8"/>
            <TextBox Height="35" Text="{Binding ClientLogoPath}"/>
            <Border Margin="0,8,0,0"
                    Width="140" Height="70"
                    Background="{DynamicResource App.LogoFrameBrush}"
                    BorderBrush="{DynamicResource App.LogoFrameBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                            <Image Source="{Binding ClientLogoPreview}"
                       Stretch="Uniform"
                       Margin="8"/>
            </Border>
            <Button Content="Browse…" Width="120" Margin="0,8,0,0" Command="{Binding BrowseClientLogoCommand}"/>

            <TextBlock Text="Connection String" Margin="0,14,0,0" Opacity="0.8"/>
            <TextBox Height="70"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Text="{Binding ConnectionString}"/>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Apply Theme" Width="140" Margin="0,0,8,0" Command="{Binding ApplyThemeCommand}"/>
                <Button Content="Save" Width="120" Margin="0,0,8,0" Command="{Binding SaveCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding Status}" Margin="0,12,0,0" Opacity="0.8"/>
        </StackPanel>
    </Grid>
</UserControl>