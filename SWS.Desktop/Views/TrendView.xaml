<UserControl x:Class="SWS.Desktop.Views.TrendView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:SWS.Desktop.ViewModels">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="220"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Grid Grid.Column="0" Background="{DynamicResource App.SurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="14,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource App.BorderBrush}">
                <StackPanel>
                    <TextBlock Text="POINTS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource App.MutedTextBrush}"/>
                    <TextBlock Text="{Binding Status}"
                               FontSize="11"
                               Foreground="{DynamicResource App.MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Available points list — bound to the grouped CollectionView -->
            <ListBox x:Name="PointPickerList" Grid.Row="1"
                     ItemsSource="{Binding AvailablePointsView}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           Padding="14,8,0,4"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource App.MutedTextBrush}"
                                           Background="{DynamicResource App.Surface2Brush}"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="14,7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Surface2Brush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TrendablePointVm}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Dto.Label}"
                                           FontSize="12"
                                           Foreground="{DynamicResource App.TextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Dto.Unit}"
                                           FontSize="10"
                                           Foreground="{DynamicResource App.MutedTextBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="+"
                                    Width="24" Height="24"
                                    FontSize="14" Padding="0"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.AddToChartCommand,
                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ON CHART label -->
            <Border Grid.Row="2" Padding="14,6"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource App.BorderBrush}"
                    Background="{DynamicResource App.Surface2Brush}">
                <TextBlock Text="ON CHART"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource App.MutedTextBrush}"/>
            </Border>

            <!-- Selected series list -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SelectedSeries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SelectedSeriesVm}">
                            <Border Padding="10,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource App.BorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Colour swatch -->
                                    <Border Grid.Column="0"
                                            Width="10" Height="10"
                                            CornerRadius="2"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding ColorHex,
                                                Converter={StaticResource HexToColorBrushConverter}}"/>

                                    <!-- Label + point count -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource App.TextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource App.MutedTextBrush}">
                                            <Run Text="{Binding PointCount, Mode=OneWay,
                                                        StringFormat='{}{0:N0} pts'}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding Unit, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Remove button -->
                                    <Button Grid.Column="2"
                                            Content="x"
                                            Width="20" Height="20"
                                            FontSize="12" Padding="0"
                                            VerticalAlignment="Top"
                                            Command="{Binding DataContext.RemoveFromChartCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource App.BorderBrush}"
                      Cursor="SizeWE"/>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Padding="14,10"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource App.BorderBrush}"
                    Background="{DynamicResource App.SurfaceBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="Range:"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource App.MutedTextBrush}"
                               Margin="0,0,8,0"/>

                    <ComboBox ItemsSource="{Binding RangeOptions}"
                              SelectedItem="{Binding SelectedRange, Mode=TwoWay}"
                              Height="28" Padding="8,3" MinWidth="120">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource TimeRangeConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Custom date pickers -->
                    <StackPanel Orientation="Horizontal"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCustomRange}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel.Resources>
                            <Style TargetType="DatePicker">
                                <Setter Property="Height" Value="28"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource App.ControlBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DatePicker">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="28"/>
                                                    </Grid.ColumnDefinitions>
                                                    <DatePickerTextBox x:Name="PART_TextBox"
                                                                       Grid.Column="0"
                                                                       Foreground="{TemplateBinding Foreground}"
                                                                       Background="Transparent"
                                                                       BorderThickness="0"
                                                                       Padding="6,0"
                                                                       VerticalContentAlignment="Center"
                                                                       CaretBrush="{DynamicResource App.ForegroundBrush}"/>
                                                    <Button x:Name="PART_Button"
                                                            Grid.Column="1"
                                                            Focusable="False"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                        <Path Data="M3,1 H5 V0 H6 V1 H10 V0 H11 V1 H13 V11 H3 Z M3,4 H13 M6,2 V4 M10,2 V4"
                                                              Stroke="{DynamicResource App.MutedTextBrush}"
                                                              StrokeThickness="1"
                                                              Width="13" Height="11"
                                                              Stretch="Uniform"/>
                                                    </Button>
                                                    <Popup x:Name="PART_Popup"
                                                           AllowsTransparency="True"
                                                           Placement="Bottom"
                                                           StaysOpen="False"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Resources>
                                    <!-- Calendar popup dark theme -->
                                    <Style TargetType="Calendar">
                                        <Setter Property="Background" Value="{DynamicResource App.ControlBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource App.BorderBrush}"/>
                                    </Style>
                                    <Style TargetType="CalendarDayButton">
                                        <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsInactive" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource App.MutedTextBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="CalendarButton">
                                        <Setter Property="Foreground" Value="{DynamicResource App.ForegroundBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource App.AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="CalendarItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CalendarItem">
                                                    <ControlTemplate.Resources>
                                                        <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource App.MutedTextBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,4"/>
                                                        </DataTemplate>
                                                    </ControlTemplate.Resources>
                                                    <Border Background="{DynamicResource App.SurfaceBrush}"
                                                            BorderBrush="{DynamicResource App.BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <StackPanel>
                                                            <!-- Month/Year navigation header -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="28"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Button x:Name="PART_PreviousButton"
                                                                        Grid.Column="0"
                                                                        Content="&#9664;"
                                                                        FontSize="10"
                                                                        Foreground="{DynamicResource App.TextBrush}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Cursor="Hand"
                                                                        Focusable="False"/>
                                                                <Button x:Name="PART_HeaderButton"
                                                                        Grid.Column="1"
                                                                        Foreground="{DynamicResource App.TextBrush}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        FontSize="12"
                                                                        FontWeight="SemiBold"
                                                                        Cursor="Hand"
                                                                        Focusable="False"/>
                                                                <Button x:Name="PART_NextButton"
                                                                        Grid.Column="2"
                                                                        Content="&#9654;"
                                                                        FontSize="10"
                                                                        Foreground="{DynamicResource App.TextBrush}"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Cursor="Hand"
                                                                        Focusable="False"/>
                                                            </Grid>
                                                            <!-- Day grid -->
                                                            <Grid x:Name="PART_MonthView" Margin="6,0,6,6"/>
                                                            <!-- Year/Decade grid -->
                                                            <Grid x:Name="PART_YearView"
                                                                  Visibility="Hidden"
                                                                  Margin="6,0,6,6"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Style.Resources>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock Text="From:" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource App.MutedTextBrush}"
                                                       FontSize="12" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding CustomFrom, Mode=TwoWay}"
                                                       Margin="0,0,12,0"/>
                        <TextBlock Text="To:" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource App.MutedTextBrush}"
                                                       FontSize="12" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding CustomTo, Mode=TwoWay}"/>
                    </StackPanel>

                    <Button Content="Load"
                            Padding="14,5" Margin="12,0,0,0"
                            Command="{Binding RefreshCommand}"/>

                    <TextBlock Text="Loading..."
                               FontSize="11" Margin="12,0,0,0"
                               Foreground="{DynamicResource App.MutedTextBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </Border>

            <!-- Chart area -->
            <Grid Grid.Row="1">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasSeries,
                                Converter={StaticResource InverseBoolToVisibility}}">
                    <TextBlock Text="No series selected"
                               FontSize="16"
                               Foreground="{DynamicResource App.MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Click + next to a point on the left, then press Load."
                               FontSize="12"
                               Foreground="{DynamicResource App.MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Chart -->
                <lvc:CartesianChart
                    x:Name="MainChart"
                    Series="{Binding Series}"
                    XAxes="{Binding XAxes}"
                    YAxes="{Binding YAxes}"
                    Background="Transparent"
                    MinHeight="100"
                    MinWidth="100"
                    Margin="8"
                    Visibility="{Binding HasSeries,
                        Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
